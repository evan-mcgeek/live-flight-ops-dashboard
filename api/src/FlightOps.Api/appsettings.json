{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenSkySettings": {
    "TokenUrl": "https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token",
    "ApiBaseUrl": "https://opensky-network.org/api"
  },
  "Token": {
    "RefreshMargin": "00:01:00"
  },
  "Broadcast": {
    "Interval": "00:00:05"
  }
}
